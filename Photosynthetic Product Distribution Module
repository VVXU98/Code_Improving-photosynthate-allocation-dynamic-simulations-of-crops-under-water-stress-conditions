      ygr := ygr_o;
    end
    else if (dvi > 0.2) and (dvi <= 0.4) then
    begin
      pr := pr_o + max(-0.2, min(0.1, 0.9758 - 0.6136*w_i - 4.8023*dvi + 0.3529*Sqr(w_i) + 1.7647*w_i*dvi + 5.8434*Sqr(dvi)));
      pl := min(1-pr, pl_o + max(-0.1, min(0.29,-8.7335 - 2.8403*w_i + 50.9339*dvi + 0.8195*Sqr(w_i) + 8.2870*w_i*dvi - 72.4986*Sqr(dvi))));
