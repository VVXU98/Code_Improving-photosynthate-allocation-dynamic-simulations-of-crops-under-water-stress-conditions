      ygr := ygr_o;
    end
    else if (dvi > 0.2) and (dvi <= 0.4) then
    begin
      pr  := pr_o  + max(-0.25, min(-0.2, 0.6041 - 1.0931*w_i - 6.2235*dvi + 0.3362*Sqr(w_i) + 3.8381*w_i*dvi + 11.3488*Sqr(dvi)));
      pl  := min(1-pr, pl_o  + max(0.05, min(0.22, -3.0875 + 4.2028*w_i + 24.0197*dvi - 1.2182*Sqr(w_i) - 14.8892*w_i*dvi - 43.5652*Sqr(dvi))));
