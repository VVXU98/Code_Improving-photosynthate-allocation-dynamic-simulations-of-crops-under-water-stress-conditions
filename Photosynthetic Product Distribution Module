    else if (dvi > 1.6) and (dvi <= 1.8) then
    begin
      pr  := pr_o  + max(-0.15, min(0, 259.8466 + 3.6695*w_i - 295.7268*dvi - 0.0263*Sqr(w_i) - 1.9621*w_i*dvi + 84.0547*Sqr(dvi)));
