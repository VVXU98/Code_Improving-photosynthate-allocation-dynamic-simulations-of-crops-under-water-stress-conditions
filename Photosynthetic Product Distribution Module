      ygr := max(0,ygr_o + max(-0.6, min(0.3, -246.1303 + 8.9505*w_i + 263.1310*dvi + 0.8978*Sqr(w_i) - 9.5751*w_i*dvi - 70.4251*Sqr(dvi))));
    end;

end;

end;
