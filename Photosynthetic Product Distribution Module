unction mod_pl_pr(cropidx, dvi, etc,wd_s, pr_o, pl_o, ygr_o: double; var pr, pl, ygr: double): boolean;
  //修正PR，PL


function mod_pl_pr(cropidx, dvi, etc, wd_s, pr_o, pl_o, ygr_o: Double; var pr, pl, ygr: Double): Boolean;
var
w_i:double;

begin
Result := True;

if (cropidx > 0) then
begin
    if (dvi > 0.0) and (dvi <= 2) then
    begin
      pr := pr_o;
      pl := pl_o;
      ygr := ygr_o;
    end;

end;

w_i := etc-wd_s;

if (cropidx = 2) then
begin
    if (dvi > 0.0) and (dvi <= 0.2) then
    begin
      pr := pr_o + min(0.05, 0.1550 - 0.2883*w_i - 0.5127*dvi - 0.1348*Sqr(w_i) + 1.4717*w_i*dvi + 1.4016*Sqr(dvi));
