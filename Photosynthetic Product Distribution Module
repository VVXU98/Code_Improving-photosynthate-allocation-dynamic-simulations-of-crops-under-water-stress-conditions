    else if (dvi > 0.4) and (dvi <= 0.6) then
    begin
      pr  := pr_o  + max(-0.25, min(0.0, 5.2713 - 0.6722*w_i - 26.8636*dvi + 0.0029*Sqr(w_i) + 1.5186*w_i*dvi + 31.6413*Sqr(dvi)));
      pl  := min(1-pr, pl_o  + max(0.0, min(0.22, 1.7433 + 0.1173*w_i - 5.4067*dvi + 0.0660*Sqr(w_i) - 0.4239*w_i*dvi + 4.3198*Sqr(dvi))));
      ygr := ygr_o;
    end
    else if (dvi > 0.6) and (dvi <= 0.8) then
    begin
      pr  := pr_o  + max(-0.05, min(0.05, -0.8921 + 0.8006*w_i + 2.2180*dvi + 0.0197*Sqr(w_i) - 1.1127*w_i*dvi - 1.3768*Sqr(dvi)));
      pl  := max(0, pl_o  + max(-0.2, min(0.11, -1.5056 - 0.0900*w_i + 3.4440*dvi - 0.0010*Sqr(w_i) + 0.1287*w_i*dvi - 2.2700*Sqr(dvi))));
      ygr := ygr_o + max(-0.03, min(0.2, 2.2627 - 2.8402*w_i - 5.4804*dvi - 0.0855*Sqr(w_i) + 3.9744*w_i*dvi + 3.3642*Sqr(dvi)));
    end
    else if (dvi > 0.8) and (dvi <= 1.0) then
    begin
      pr  := pr_o;
      pl  := max(0, pl_o + max(-0.2, min(0.11, 29.5602 - 0.4267*w_i - 69.8962*dvi - 0.0017*Sqr(w_i) + 0.4830*w_i*dvi + 41.1561*Sqr(dvi))));
      ygr := max(0, ygr_o + max(-0.07, min(0.35, -65.1742 + 0.4001*w_i + 151.2468*dvi - 0.0028*Sqr(w_i) - 0.1010*w_i*dvi - 87.5066*Sqr(dvi))));
    end
    else if (dvi > 1.0) and (dvi <= 1.2) then
    begin
      pr  := pr_o  + max(0, min(0.12, -6.0841 + 1.1055*w_i + 9.5896*dvi - 0.0092*Sqr(w_i) - 1.0119*w_i*dvi - 3.6229*Sqr(dvi)));
      pl  := pl_o  + max(0.05, min(0.45, abs(-118.0775 + 2.2616*w_i + 206.5870*dvi + 1.8655*Sqr(w_i) - 1.7361*w_i*dvi - 90.1878*Sqr(dvi))));
      ygr := max(0, ygr_o + max(-0.14, min(0.3, 12.1395 - 0.0462*w_i - 19.8570*dvi - 0.0538*Sqr(w_i) + 0.0310*w_i*dvi + 7.9935*Sqr(dvi))));
    end
    else if (dvi > 1.2) and (dvi <= 1.4) then
    begin
      pr  := pr_o  + max(0, min(0.12, 117.8466 - 1.7445*w_i - 172.0068*dvi + 0.0392*Sqr(w_i) + 1.1813*w_i*dvi + 62.8460*Sqr(dvi)));
      pl  := pl_o  + max(0, min(0.4, -212.9975 + 4.6427*w_i + 311.2991*dvi - 0.0717*Sqr(w_i) - 2.2759*w_i*dvi - 113.6734*Sqr(dvi)));
      ygr := max(0,ygr_o + max(-0.48, min(0.17, 120.5244 - 2.8026*w_i - 175.8424*dvi + 0.0533*Sqr(w_i) + 1.7212*w_i*dvi + 64.0421*Sqr(dvi))));
    end
    else if (dvi > 1.4) and (dvi <= 1.6) then
    begin
      pr  := pr_o  + max(-0.05, min(0.12, 174.4192 + 9.2097*w_i - 247.6454*dvi + 0.1300*Sqr(w_i) - 6.5471*w_i*dvi + 87.9175*Sqr(dvi)));
      pl  := pl_o;
      ygr := max(0, ygr_o + max(-0.5, min(0, 229.1989 + 11.3813*w_i - 326.1033*dvi + 0.1594*Sqr(w_i) - 8.1095*w_i*dvi + 115.8283*Sqr(dvi))));
