    end
    else if (dvi > 0.4) and (dvi <= 0.6) then
    begin
      pr := pr_o + max(-0.26, min(0.1, 0.2009 + 0.2626*w_i - 1.9232*dvi - 0.0230*Sqr(w_i) - 0.1650*w_i*dvi + 2.2408*Sqr(dvi)+0.05));
      pl := min(1-pr,pl_o + max(-0.16, min(0.39, -1.9925 - 1.2333*w_i + 7.9166*dvi + 0.0149*Sqr(w_i) + 2.3210*w_i*dvi - 7.1042*Sqr(dvi)+0.05)));
      ygr := 0;
    end
    else if (dvi > 0.6) and (dvi <= 0.8) then
    begin
      pr := pr_o + max(-0.11, min(0.0, 0.2103 - 0.0744*w_i - 1.1638*dvi + 0.0156*Sqr(w_i) + 0.1010*w_i*dvi + 1.0816*Sqr(dvi)));
      pl := pl_o + max(-0.15, min(0.35, -2.3455 - 0.5055*w_i + 9.1461*dvi + 0.1439*Sqr(w_i) + 0.8144*w_i*dvi - 8.3289*Sqr(dvi)));
      ygr := 0;
    end
    else if (dvi > 0.8) and (dvi <= 1.0) then
    begin
      pr := pr_o + max(-0.12, min(0.15, -0.0300 + 0.0174*w_i - 0.4882*dvi - 0.0033*Sqr(w_i) - 0.0133*w_i*dvi + 0.5847*Sqr(dvi)));
      pl := pl_o +  max(-0.17, min(0.46, -5.2842 + 0.3732*w_i + 11.3076*dvi + 0.0526*Sqr(w_i) - 0.6400*w_i*dvi - 5.6375*Sqr(dvi)));
      ygr := max(0, ygr_o + max(-0.43, min(0.25, -0.5699 - 0.2802*w_i + 0.8430*dvi + 0.0060*Sqr(w_i) + 0.3211*w_i*dvi - 0.7207*Sqr(dvi))));
    end
    else if (dvi > 1.0) and (dvi <= 1.2) then
    begin
      pr := pr_o + max(-0.06, min(0.06, 3.9770 + 0.6277*w_i - 7.8229*dvi - 0.0007*Sqr(w_i) - 0.6624*w_i*dvi + 3.7689*Sqr(dvi)));
      pl := pl_o + max(0, min(0.36, -27.7510 - 1.0956*w_i + 54.0125*dvi + 0.0699*Sqr(w_i) + 0.9538*w_i*dvi - 26.1165*Sqr(dvi)));
      ygr := max(0, ygr_o + max(-1.8, min(0.4, -21.3950 - 0.7036*w_i + 45.0953*dvi - 0.0580*Sqr(w_i) + 0.9181*w_i*dvi - 23.8551*Sqr(dvi))));
    end
    else if (dvi > 1.2) and (dvi <= 1.4) then
    begin
      pr := pr_o + max(-0.1, min(0.05, -4.7177 - 0.0069*w_i + 7.4611*dvi - 0.0367*Sqr(w_i) + 0.0564*w_i*dvi - 2.9658*Sqr(dvi)));
      pl := pl_o + max(0.0, min(0.2, 1.3963 + 0.4181*w_i - 1.8247*dvi - 0.0126*Sqr(w_i) - 0.2957*w_i*dvi + 0.5889*Sqr(dvi)));
      ygr := max(0, ygr_o + max(-3.85, min(-0.68, -8.4878 + 6.0811*w_i + 12.7324*dvi - 0.0560*Sqr(w_i) - 4.7572*w_i*dvi - 6.0157*Sqr(dvi))));
    end
    else if (dvi > 1.4) and (dvi <= 1.6) then
    begin
      pr := pr_o +  max(-0.06, min(0, -21.9069 - 1.3123*w_i + 28.9790*dvi - 0.0190*Sqr(w_i) + 0.8589*w_i*dvi - 9.6046*Sqr(dvi)));
      pl := pl_o;
      ygr := max(0, ygr_o + max(-5, min(0, -273.1220 - 5.7132*w_i + 379.6431*dvi - 0.2139*Sqr(w_i) + 4.3493*w_i*dvi - 133.4108*Sqr(dvi))));
    end
    else if (dvi > 1.6) and (dvi <= 1.8) then
    begin
      pr := pr_o + max(-0.06, min(-0.03, 29.7964 + 1.8656*w_i - 38.6922*dvi + 0.0035*Sqr(w_i) - 0.8351*w_i*dvi + 12.2155*Sqr(dvi)));
      pl := pl_o;
      ygr := max(1.5, ygr_o + max(-6.4, min(0, -510.1331 + 1.2294*w_i + 612.2675*dvi + 0.6924*Sqr(w_i) - 1.9609*w_i*dvi - 184.7477*Sqr(dvi))));
    end
    else if (dvi > 1.8) and (dvi <= 2.0) then
    begin
      pr := pr_o + max(-0.06, min(0, 9.7788 - 14.4081*w_i - 9.0631*dvi - 0.2569*Sqr(w_i) + 7.7565*w_i*dvi + 2.0411*Sqr(dvi)));
      pl := pl_o;
      ygr := max(0, ygr_o + max(-7.5, min(0, -abs(-560.3101 + 285.6174*w_i + 548.1205*dvi + 8.4200*Sqr(w_i) - 157.4064*w_i*dvi - 136.4700*Sqr(dvi)))));
